# SpaceLab Backend .gitignore

# Go 二进制文件
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# 测试二进制文件
*.test

# 覆盖率文件
*.out
*.prof

# 环境配置（不提交）
.env
.env.local
.env.*.local

# Docker 卷数据
postgres_data/
redis_data/
uploads/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~

# OS 文件
.DS_Store
Thumbs.db
desktop.ini

# 日志
*.log
logs/

# 缓存
.cache/
tmp/
temp/

# 依赖（Go modules）
vendor/

# 构建产物
dist/
build/
out/

# 临时文件
*.tmp
*.bak
*.bakup
