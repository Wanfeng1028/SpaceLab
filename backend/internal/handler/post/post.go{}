package handler

import (
	"net/http"
	"strconv"

	"github.com/gin-gonic/gin"
	"github.com/spacelab/backend/internal/model"
	"github.com/spacelab/backend/internal/service"
	"github.com/spacelab/backend/internal/utils"
)

type PostHandler struct {
	postService *service.PostService
}

func NewPostHandler(postService *service.PostService) *PostHandler {
	return &PostHandler{postService: postService}
}

// ListPosts 获取文章列表
func (h *PostHandler) ListPosts(c *gin.Context) {
	page, _ := strconv.Atoi(c.DefaultQuery("page", "1"))
	pageSize, _ := strconv.Atoi(c.DefaultQuery("page_size", "10"))
	status := c.Query("status")
	language := c.Query("language")
	category := c.Query("category")

	if page < 1 {
		page = 1
	}
	if pageSize < 1 || pageSize > 100 {
		pageSize = 10
	}

	// 非管理员只能看已发布文章
	userRole, _ := c.Get("role")
	if userRole != "admin" && userRole != "writer" {
		if status != "" && status != "published" {
			c.JSON(http.StatusForbidden, gin.H{"error": "Access denied"})
			return
		}
		status = "published"
	}

	posts, total, err := h.postService.ListPosts(status, language, category, page, pageSize)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Failed to fetch posts"})
		return
	}

	response := struct {
		Posts      []model.Post `json:"posts"`
		Total      int64        `json:"total"`
		Page       int          `json:"page"`
		PageSize   int          `json:"page_size"`
		TotalPages int          `json:"total_pages"`
	}{
		Posts:     posts,
		Total:     total,
		Page:      page,
		PageSize:  pageSize,
		TotalPages: int((total + int64(pageSize-1)) / int64(pageSize)),
	}

	c.JSON(http.StatusOK, response)
}

// GetPostBySlug 获取文章详情
func (h *PostHandler) GetPostBySlug(c *gin.Context) {
	slug := c.Param("id")

	post, err := h.postService.GetPostBySlug(slug)
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "Post not found"})
		return
	}

	// 草稿/归档文章只有管理员/作者可访问
	if post.Status != "published" {
		userRole, _ := c.Get("role")
		userID, _ := c.Get("user_id")
		if userRole != "admin" && userRole != "writer" && userID != post.AuthorID.String() {
			c.JSON(http.StatusNotFound, gin.H{"error": "Post not found"})
			return
		}
	}

	c.JSON(http.StatusOK, post)
}

// CreatePost 创建文章
func (h *PostHandler) CreatePost(c *gin.Context) {
	var input service.CreatePostInput
	if err := c.ShouldBindJSON(&input); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid request parameters"})
		return
	}

	// 设置作者为当前用户
	input.AuthorID = c.GetString("user_id")

	// 清洗文章内容
	input.Content = utils.SanitizeRichText(input.Content)
	input.Summary = utils.SanitizePlainString(input.Summary)
	input.Title = utils.SanitizePlainString(input.Title)

	post, err := h.postService.CreatePost(input)
	if err != nil {
		errMsg := utils.SafeErrorMessage(err, "Failed to create post")
		c.JSON(http.StatusInternalServerError, gin.H{"error": errMsg})
		return
	}

	// 审计日志
	utils.LogAudit(
		c.GetString("user_id"), c.GetString("email"),
		"create", "post", post.ID.String(),
		map[string]interface{}{"title": post.Title, "status": post.Status},
		c.ClientIP(), c.GetHeader("User-Agent"),
	)

	c.JSON(http.StatusCreated, post)
}

// UpdatePost 更新文章
func (h *PostHandler) UpdatePost(c *gin.Context) {
	id := c.Param("id")

	var input service.UpdatePostInput
	if err := c.ShouldBindJSON(&input); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid request parameters"})
		return
	}

	// 清洗文章内容
	if input.Content != nil {
		sanitized := utils.SanitizeRichText(*input.Content)
		input.Content = &sanitized
	}
	if input.Summary != nil {
		sanitized := utils.SanitizePlainString(*input.Summary)
		input.Summary = &sanitized
	}
	if input.Title != nil {
		sanitized := utils.SanitizePlainString(*input.Title)
		input.Title = &sanitized
	}

	post, err := h.postService.UpdatePost(id, input)
	if err != nil {
		errMsg := utils.SafeErrorMessage(err, "Failed to update post")
		c.JSON(http.StatusInternalServerError, gin.H{"error": errMsg})
		return
	}

	// 审计日志
	utils.LogAudit(
		c.GetString("user_id"), c.GetString("email"),
		"update", "post", id,
		map[string]interface{}{"title": post.Title},
		c.ClientIP(), c.GetHeader("User-Agent"),
	)

	c.JSON(http.StatusOK, post)
}

// DeletePost 删除文章
func (h *PostHandler) DeletePost(c *gin.Context) {
	id := c.Param("id")

	err := h.postService.DeletePost(id)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Failed to delete post"})
		return
	}

	// 审计日志
	utils.LogAudit(
		c.GetString("user_id"), c.GetString("email"),
		"delete", "post", id,
		nil, c.ClientIP(), c.GetHeader("User-Agent"),
	)

	c.JSON(http.StatusOK, gin.H{"message": "Post deleted successfully"})
}

// PublishPost 发布文章
func (h *PostHandler) PublishPost(c *gin.Context) {
	id := c.Param("id")

	post, err := h.postService.PublishPost(id)
	if err != nil {
		errMsg := utils.SafeErrorMessage(err, "Failed to publish post")
		c.JSON(http.StatusInternalServerError, gin.H{"error": errMsg})
		return
	}

	// 审计日志
	utils.LogAudit(
		c.GetString("user_id"), c.GetString("email"),
		"publish", "post", id,
		map[string]interface{}{"title": post.Title},
		c.ClientIP(), c.GetHeader("User-Agent"),
	)

	c.JSON(http.StatusOK, post)
}

// IncrementViewCount 增加阅读量
func (h *PostHandler) IncrementViewCount(c *gin.Context) {
	id := c.Param("id")

	err := h.postService.IncrementViewCount(id)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "Failed to increment view count"})
		return
	}

	c.JSON(http.StatusOK, gin.H{"message": "View count incremented"})
}
