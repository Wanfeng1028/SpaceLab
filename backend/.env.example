# SpaceLab Backend Configuration
# 复制此文件为 .env 并修改配置

# Server
SERVER_PORT=8080
ENVIRONMENT=development

# Database
DATABASE_URL=postgres://spacelab:spacelab_password@localhost:5432/spacelab?sslmode=disable

# Redis (optional, set empty to disable)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRATION=24h

# CORS
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_PATH=./uploads

# reCAPTCHA v3 (optional, set empty to skip)
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# Resend Transactional Email (optional)
RESEND_API_KEY=
RESEND_FROM=noreply@tx.yourdomain.com

# MailerLite Newsletter (optional)
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
MAILERLITE_BASE_URL=https://api.mailerlite.com/api/v2

# LiveComment (optional)
LIVECOMMENT_SITE_ID=
