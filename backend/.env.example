# SpaceLab 后端环境变量配置模板

# ===========================================
# 服务器配置
# ===========================================
SERVER_PORT=8080
ENVIRONMENT=development

# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL=postgres://spacelab:spacelab_password@localhost:5432/spacelab?sslmode=disable

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# ===========================================
# Redis 配置（可选）
# ===========================================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ===========================================
# LiveComment 配置
# ===========================================
LIVECOMMENT_SITE_ID=your-livecomment-site-id

# ===========================================
# 文件上传配置
# ===========================================
MAX_UPLOAD_SIZE=10485760
UPLOAD_PATH=./uploads

# ===========================================
# CORS 配置
# ===========================================
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080

# ===========================================
# SMTP 邮件配置（可选）
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@spacelab.com

# ===========================================
# 网站 URL
# ===========================================
SITE_URL=http://localhost:4200
