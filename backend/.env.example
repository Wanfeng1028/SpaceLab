# SpaceLab 后端环境变量配置模板

# ===========================================
# 服务器配置
# ===========================================
SERVER_PORT=8080
ENVIRONMENT=development

# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL=postgres://spacelab:spacelab_password@localhost:5432/spacelab?sslmode=disable

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# ===========================================
# Redis 配置（可选）
# ===========================================
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ===========================================
# LiveComment 配置
# ===========================================
LIVECOMMENT_SITE_ID=your-livecomment-site-id

# ===========================================
# 文件上传配置
# ===========================================
MAX_UPLOAD_SIZE=10485760
UPLOAD_PATH=./uploads

# ===========================================
# CORS 配置
# ===========================================
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080

# ===========================================
# Resend 邮件配置（交易邮件：登录注册、验证码、找回密码）
# ===========================================
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=noreply@tx.yourdomain.com

# ===========================================
# MailerLite 配置（Newsletter：每周推送）
# ===========================================
MAILERLITE_API_KEY=your_mailerlite_api_key_here
MAILERLITE_GROUP_ID=your_newsletter_group_id
MAILERLITE_BASE_URL=https://api.mailerlite.com/api/v2

# ===========================================
# 网站 URL
# ===========================================
SITE_URL=http://localhost:4200
