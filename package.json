{
  "name": "spacelab",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/build-content.mjs && node scripts/build-lab-tools-pages.mjs && ng serve",
    "prebuild": "node scripts/check-i18n.mjs && node scripts/build-content.mjs && node scripts/build-lab-tools-pages.mjs && node scripts/generate-github-meta.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "echo 'No tests configured'",
    "new:post": "node scripts/new-post.mjs",
    "new:project": "node scripts/new-project.mjs"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "21.2",
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.12",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.14",
    "@angular/router": "^21.2.0",
    "delaunator": "^5.1.0",
    "dompurify": "^3.4.7",
    "geojson": "^0.5.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lodash-es": "^4.18.1",
    "markdown-it": "^14.2.0",
    "ng-zorro-antd": "^21.3.1",
    "rxjs": "~7.8.0",
    "three": "^0.184.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.0",
    "@types/delaunator": "^5.0.3",
    "@types/dompurify": "^3.0.5",
    "@types/geojson": "^7946.0.16",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.2",
    "@types/three": "^0.184.1",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.12",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
